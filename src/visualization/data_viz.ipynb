    "fig, ax= plt.subplots(figsize=(10, 6))\n",
    "ax.bar(state_revenue.index, state_revenue.values)\n",
    "ax.set_title('Top 10 States By Revenue')\n",
    "ax.set_xlabel('States')\n",
    "ax.set_ylabel('Revenue')"
